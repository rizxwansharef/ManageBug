<nav class="navbar navbar-expand-lg navbar-light bg-light mb-3">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">
      
        ManageBug
    </a>

    <div class="d-flex align-items-center">
      <%= link_to 'Projects', projects_path, class: 'btn btn-outline-primary me-2' %>
      <%= link_to 'Bugs', bugs_path, class: 'btn btn-outline-secondary me-3' %>
      <%= link_to 'Notifications', notifications_path, class: 'btn btn-outline-info me-3' %>

      <div class="dropdown">
        <a class="btn btn-light dropdown-toggle d-flex align-items-center" href="#" role="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
          <% if current_user&.profile_picture&.attached? %>
            <%= image_tag current_user.profile_picture, class: 'rounded-circle me-2', style: 'width:32px;height:32px;object-fit:cover;' %>
          <% else %>
            <span class="rounded-circle bg-secondary text-white text-center me-2" style="width:32px;height:32px;display:inline-flex;align-items:center;justify-content:center;">
              <%= current_user&.name&.first&.upcase || '?' %>
            </span>
          <% end %>
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
          <li><%= link_to 'Profile', edit_user_registration_path, class: 'dropdown-item' %></li>
          <li>
            <%= link_to 'Sign out', destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: 'Sign out?' }, class: 'dropdown-item' %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>
