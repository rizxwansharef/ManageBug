<nav class="navbar navbar-expand-lg navbar-light bg-light mb-3">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="<%= projects_path %>" style="font-size: 1.5rem; color: #000;">
      ManageBug
    </a>
    <div class="d-flex align-items-center">
      <%= link_to 'Projects', projects_path , class: 'me-2 fw-bold', style: 'color: #000; text-decoration: none;padding-right:1rem'; %>
      <div class="dropdown" , style="padding-right :20px">
        <a class="btn btn-bold dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"; > Bugs</a>
        <ul class="dropdown-menu dropdown-menu-end">
          <% Bug.order(id: :desc).limit(5).each do |bug| %>
            <li><%= link_to bug.title, bug_path(bug), class: "dropdown-item" %></li>
          <% end %>
          <li><hr class="dropdown-divider"></li>
          <li><%= link_to "All Bugs",  bugs_path, class: "dropdown-item" %></li>
        </ul>
      </div>
      <%= link_to notifications_path, class: 'me-3' do %>
        <i class="bi bi-bell" style="font-size: 1.2rem; color: #000;"></i>
      <% end %>

      <div class="dropdown">
        <a class="btn btn-light dropdown-toggle d-flex align-items-center" href="#" role="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
          <% if current_user&.profile_picture&.attached? %>
            <%= image_tag current_user.profile_picture, class: 'rounded-circle me-2', style: 'width:32px;height:32px;object-fit:cover;' %>
          <% else %>
            <span class="rounded-circle bg-secondary text-white text-center me-2" style="width:32px;height:32px;display:inline-flex;align-items:center;justify-content:center;">
              <%= current_user&.name&.first&.upcase || '?' %>
            </span>
          <% end %>
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
          <li><%= link_to 'Profile', edit_user_registration_path, class: 'dropdown-item' %></li>
          <li>
            <%= link_to 'Sign out', destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: 'Sign out?' }, class: 'dropdown-item' %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>


