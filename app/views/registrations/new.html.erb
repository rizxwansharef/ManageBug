<div class="auth-shell">
  <div class="auth-visual d-none d-lg-flex">
    <div class="auth-visual__brand">ManageBug</div>
  </div>

  <div class="auth-panel">

    <div class="auth-card">
      <h2>Sign Up</h2>
      <p class="auth-subtitle">Fill your information below</p>

      

      <%= render "registrations/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form", multipart: true }) do |f| %>
        <%= f.hidden_field :role, value: @selected_role %>

        <div class="mb-3">
        
          <%= f.label :name, class: "form-label auth-label" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control auth-input" %>
        </div>

        <div class="mb-3">
          <%= f.label :email, class: "form-label auth-label" %>
          <%= f.email_field :email, autocomplete: "email", class: "form-control auth-input" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, class: "form-label auth-label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control auth-input" %>
          <% if @minimum_password_length %>
            <div class="auth-hint"><%= @minimum_password_length %> characters minimum</div>
          <% end %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, class: "form-label auth-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control auth-input" %>
        </div>

        <div class="mb-4">
          <%= f.label :profile_picture, class: "form-label auth-label" %>
          <%= f.file_field :profile_picture, class: "form-control auth-input" %>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <%= f.submit "Sign Up", class: "btn btn-primary auth-submit auth-submit--inline" %>
        </div>
      <% end %>

      <div class="auth-footer">
        <span>Already have an account?</span>
        <%= link_to "Login to your account", new_user_session_path %>
      </div>
    </div>
  </div>
</div>