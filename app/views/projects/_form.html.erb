

<%= form_with(model: project, local: true, multipart: true) do |f| %>
	<% if project.errors.any? %>
		<div class="alert alert-danger">
			<h4>There were errors saving the project</h4>
			<ul>
				<% project.errors.full_messages.each do |msg| %>
					<li><%= msg %></li>
				<% end %>
			</ul>
		</div>
	<% end %>

	<div class="mb-3">
		<%= f.label :name %>
		<%= f.text_field :name, class: 'form-control' %>
	</div>

	<div class="mb-3">
		<%= f.label :description %>
		<%= f.text_area :description, class: 'form-control', rows: 4 %>
	</div>

	<div class="mb-3">
		<%= f.label :avatar, 'Project photo' %>
		<%= f.file_field :avatar, class: 'form-control' %>
		<% if project.avatar.attached? %>
			<div class="mt-2">
				<%= image_tag project.avatar, class: 'rounded', style: 'width:72px;height:72px;object-fit:cover;' %>
			</div>
		<% end %>
	</div>

	<% if manager? %>
		<div class="mb-3">
			<%= f.label :user_ids, 'Assigned people' %>
			<div class="border rounded p-3 bg-light">
				<%= f.collection_check_boxes :user_ids, User.where.not(role: 'manager')|| User.order(:name), :id, :name do |b| %>

					<div class="form-check">
						<%= b.check_box class: 'form-check-input' %>
						<%= b.label class: 'form-check-label' %>
					</div>
				<% end %>
			</div>
		</div>
	<% end %> 

	<div class="mb-3">
		<%= f.submit class: 'btn btn-primary' %>
		<%= link_to 'Back', projects_path, class: 'btn btn-link' %>
	</div>
<% end %>
