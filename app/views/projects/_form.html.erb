

<%= form_with(model: project, local: true, multipart: true) do |f| %>
	<% if project.errors.any? %>
		<div class="alert alert-danger">
			<h4>There were errors saving the project</h4>
			<ul>
				<% project.errors.full_messages.each do |msg| %>
					<li><%= msg %></li>
				<% end %>
			</ul>
		</div>
	<% end %>

	<div class="mb-3">
		<%= f.label :name %>
		<%= f.text_field :name, class: 'form-control',required: true %>
	</div>

	<div class="mb-3">
		<%= f.label :description %>
		<%= f.text_area :description, class: 'form-control', rows: 4 %>
	</div>

	<div class="mb-3">
		<%= f.label :avatar, 'Project photo' %>
		<%= f.file_field :avatar, class: 'form-control' %>
		<% if project.avatar.attached? %>
			<div class="mt-2">
				<%= image_tag project.avatar, class: 'rounded', style: 'width:72px;height:72px;object-fit:cover;' %>
			</div>
		<% end %>
	</div>

	<% if manager? %>
		<div class="mb-4">
			<%= f.label :user_ids, 'Assigned people', class: "form-label fw-bold" %>
			<div class="assign-list shadow-sm">
				<%= f.collection_check_boxes :user_ids, User.where.not(role: 'manager').order(:name), :id, :name do |b| %>
					<% user = b.object %>
					<label class="assign-list__item border-bottom mb-0">
						<div class="assign-list__avatar">
							<% if user.profile_picture.attached? %>
								<%= image_tag user.profile_picture, alt: user.name %>
							<% else %>
								<span><%= user.name.to_s.first&.upcase || "U" %></span>
							<% end %>
						</div>
						<span class="assign-list__name"><%= user.name %></span>
						<%= b.check_box class: 'assign-list__checkbox ms-auto' %>
					</label>
				<% end %>
			</div>
		</div>
	<% end %> 

	<div class="mb-3">
		<%= f.submit class: 'btn btn-primary' %>
		<%= link_to 'Back', project_path(@project), class: 'btn btn-link' %>
	</div>
<% end %>
