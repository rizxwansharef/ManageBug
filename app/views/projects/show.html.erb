<%= render 'shared/dashboard_nav' %>

<div class="container">
	<h1><%= @project.name %></h1>
	<p class="text-muted">Managed by: <%= @project.manager&.name %></p>

	<% if @project.avatar.attached? %>
		<div class="mb-3">
			<%= image_tag @project.avatar, class: 'rounded', style: 'width:120px;height:120px;object-fit:cover;' %>
		</div>
	<% end %>

	<div class="mb-4">
		<p><%= simple_format(@project.description) %></p>
	</div>

	<% if @project.users.any? %>
		<div class="mb-3">
			<h5>Assigned people</h5>
			<ul class="list-group">
				<% @project.users.order(:name).each do |user| %>
					<li class="list-group-item d-flex justify-content-between align-items-center">
						<span><%= user.name %> <span class="text-muted">(<%= user.role %>)</span></span>
						<% if user.profile_picture.attached? %>
							<%= image_tag user.profile_picture, class: 'rounded-circle', style: 'width:32px;height:32px;object-fit:cover;' %>
						<% end %>
					</li>
				<% end %>
			</ul>
		</div>
	<% end %>

	<div class="mb-3">
		<%= link_to 'Edit', edit_project_path(@project), class: 'btn btn-outline-secondary me-2' if manager? && @project.manager_id == current_user.id %>
		<%= link_to 'Delete', project_path(@project), data: { turbo_method: :delete, turbo_confirm: 'Delete project?' }, class: 'btn btn-danger' if manager? && @project.manager_id == current_user.id %>
		<%= link_to 'View Bugs', bugs_path + "?project_id=#{@project.id}", class: 'btn btn-primary ms-2' %>
	</div>
</div>
