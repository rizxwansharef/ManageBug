<%= render 'shared/dashboard_nav' %>

<div class="container app-shell py-4">
	<% if @project.avatar.attached? %>
		<div class="mb-3">
			<%= image_tag @project.avatar, class: 'rounded', style: 'width:120px;height:120px;object-fit:cover;' %>
		</div>
	<% end %>

	<div class="mb-5 text-muted" style="font-size: 1.05rem; line-height: 1.6;">
		<h2 class="page-heading mb-3"><%= @project.name %></h2>
	</div>

	<div class="row mb-5 text-muted" style="font-size: 1.05rem; line-height: 1.6; background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
		<p>Description:</p>
		<%= simple_format(@project.description) %>
	</div>

	<div class="row mb-5" style="background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
		<div class="col-auto me-4">
			<h5 class="text-uppercase text-muted" style="font-size: 0.8rem; letter-spacing: 0.05em; font-weight: 700; margin-bottom: 0.8rem;">Created by</h5>
			<% if @project.manager&.profile_picture&.attached? %>
				<%= image_tag @project.manager.profile_picture, class: 'rounded-circle shadow-sm', style: 'width:48px;height:48px;object-fit:cover;', title: @project.manager.name, data: { bs_toggle: "tooltip" } %>
			<% else %>
				<div class="rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width:48px;height:48px; background-color: #d9e3f5; color: #28436f; font-weight: 700;" title="<%= @project.manager&.name %>" data-bs-toggle="tooltip">
					<%= @project.manager&.name.to_s.first&.upcase || "U" %>
				</div>
			<% end %>
				<%=@project.manager.name %>

		</div>
	</div>

	<div class="row mb-5" style="background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">

		<% if @project.users.any? %>
			<div class="col">
				<h5 class="text-uppercase text-muted" style="font-size: 0.8rem; letter-spacing: 0.05em; font-weight: 700; margin-bottom: 0.8rem;">Assigned people</h5>
				<ul class="list-unstyled d-flex flex-column gap-2">
					<% @project.users.order(:name).each do |user| %>
						<li class="d-flex align-items-center gap-3">
						<% if user.profile_picture.attached? %>
							<div class="rounded-circle overflow-hidden flex-shrink-0" style="width: 48px; height: 48px;">
							<%= image_tag user.profile_picture, alt: user.name, class: "w-100 h-100 object-fit-cover" %>
							</div>
						<% else %>
							<div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width: 48px; height: 48px;">
							<%= user.name.to_s.first&.upcase || "U" %>
							</div>
						<% end %>
						<span class="fw-medium text-dark"><%= user.name + " " +"(" + user.role + ")" %></span>

						</li>
					<% end %>
				</ul>

			</div>
		<% end %>
	</div>

	<div class="mb-3 pt-4 border-top">
		<%= link_to 'Edit', edit_project_path(@project), class: 'btn btn-outline-secondary app-btn me-2' if manager? && @project.manager_id == current_user.id %>
		<% if can? :destroy, @project %>
			<%= button_to 'Delete', project_path(@project), method: :delete, data: { turbo_confirm: 'Delete Project?' }, class: 'btn btn-outline-danger app-btn d-inline-block', form: { class: 'd-inline-block' } %>
		<% end %>
		<% if @project.bugs.any?%>
		<%= link_to 'View Bugs', bugs_path + "?project_id=#{@project.id}", class: 'btn btn-primary app-btn me-2' %>
		<%end%>
		<%= link_to 'Back', projects_path , class: 'btn btn-outline-secondary app-btn me-2'%>
		<% if can? :create, Bug %>
		    <button class="btn btn-primary app-btn" data-bs-toggle="modal" data-bs-target="#newBugModal" type="button">New bug</button>
		<%end%>
	</div>
</div>

<% if can?(:create, Bug) %>
	<div class="modal fade" id="newBugModal" tabindex="-1" aria-labelledby="newBugModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered app-modal app-modal--bug">
			<div class="modal-content">
				<div class="modal-header border-0">
					<h2 class="modal-title app-modal__title" id="newBugModalLabel">Add new bug</h2>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>

				<div class="modal-body pt-0">
					<%= form_with(model: Bug.new(project: @project), url: bugs_path, local: true, multipart: true) do |f| %>
						<%= f.hidden_field :project_id, value: @project.id %>

						<div class="row">
							<div class="col-md-6 mb-3">
								<label class="form-label mb-1 fw-bold">Assign Dev</label>
								<div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
									<%= f.collection_radio_buttons :assignee_dev_id, @project.users.where(role: "developer").order(:name), :id, :name, {}, { required: true } do |b| %>
										<% user = b.object %>
										<label class="assign-list__item border-bottom mb-0">
											<div class="assign-list__avatar">
												<% if user.profile_picture.attached? %>
													<%= image_tag user.profile_picture, alt: user.name %>
												<% else %>
													<span><%= user.name.to_s.first&.upcase || "U" %></span>
												<% end %>
											</div>
											<span class="assign-list__name"><%= user.name %></span>
											<%= b.radio_button class: 'form-check-input ms-auto' %>
										</label>
									<% end %>
								</div>
							</div>
							
						</div>

						<div>
							<%= f.label :deadline, "Add due date", class: "form-label mb-1" %>
							<%= f.date_field :deadline, class: "form-control app-input" %>
						</div>

						<div class="mb-3 mt-2">
							<%= f.label :title, "Bug title", class: "form-label" %>
							<%= f.text_field :title, class: "form-control app-input app-input--title", placeholder: "Add title here", required: true %>
						</div>

						<div class="mb-3">
							<%= f.label :description, "Bug details", class: "form-label" %>
							<%= f.text_area :description, rows: 2, class: "form-control app-input", placeholder: "Add here", required: true %>
						</div>

						<div class="upload-dropzone mb-3">
							<%= f.label :screenshot, class: "upload-dropzone__label" do %>
								<i class="bi bi-cloud-arrow-up"></i>
								Select Image <span>browse</span>
							<% end %>
							<%= f.file_field :screenshot, class: "d-none" %>
						</div>

						<div class="modal-footer border-0 pt-2 px-0">
							<%= f.submit "Add", class: "btn btn-primary app-btn px-4" %>
						</div>
					<% end %>
				</div>
			</div>
		</div>
	</div>
<% end %>
