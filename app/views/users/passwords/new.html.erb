<div class="auth-panel">

    <div class="auth-card">
      <h2>Forgot Password?</h2>
      <p class="auth-subtitle">Enter your email below to receive password reset link</p>

  
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { class: "auth-form", method: :post }) do |f| %>
        <div class="mb-3">
        
          <%= f.label :email, class: "form-label auth-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control auth-input" %>
        </div>

  

        <div class="mb-3">
          <%= f.submit "Send me password reset instructions" , class: "btn btn-primary auth-submit auth-submit--inline" %>

        </div>
      <% end %>
    </div>
  
  <div class="auth-footer">
    <span>Back to login?</span>
    <%= link_to "Log in", new_user_session_path %>
  </div>
</div>
