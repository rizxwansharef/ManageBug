<%= render 'shared/dashboard_nav' %>

<div class="container mt-4 d-flex justify-content-center">
  <div class="notifications-panel w-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center gap-3">
        <div>
          <h1 class="mb-1">Notifications</h1>
          <p class="text-muted mb-0"><%= pluralize(@notifications.count, 'notification') %></p>
        </div>
      </div>
            <button class="btn btn-sm btn-outline-secondary" onclick="history.back()"><i class="bi bi-x-lg"></i></button>

    </div>

    <ul class="list-group notifications-list">
      <% @notifications.each do |notification| %>
        <li class="list-group-item notification-card d-flex justify-content-between align-items-start <%= notification.read? ? 'notification-read' : 'notification-unread' %>">
          <div class="flex-grow-1">
            <p class="mb-1 notification-message"><%= notification.message %></p>
          </div>
          <span class="badge notification-time rounded-pill" style="white-space: nowrap;"><%= time_ago_in_words(notification.created_at) %> ago</span>
        </li>
      <% end %>
    </ul>
    <%= button_to 'Mark all as read', mark_all_as_read_notifications_path, method: :patch, class: 'btn btn-secondary' %>
  </div>

</div>

 