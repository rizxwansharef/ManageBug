<%= form_with(model: bug, local: true, multipart: true) do |f| %>
  <%= render "bugs/status_select", bug: bug %>

  <% unless developer? %>
    <% if bug.project_id.present? || @selected_project.present? %>
      <% current_project_id = bug.project_id || @selected_project&.id %>
      <%= f.hidden_field :project_id, value: current_project_id %>
    <% else %>
      <div class="mb-3">
        <%= f.label :project_id, "Select Project", class: "form-label mb-1 fw-bold" %>
        <%= f.collection_select :project_id, @available_projects, :id, :name, { prompt: "Choose a project" }, { class: "form-select app-input", required: true, onchange: "let frame = document.getElementById('bug_assignees_frame_#{bug.id || 'new'}'); if (this.value) { frame.src = '/bugs?project_id=' + this.value; } else { frame.removeAttribute('src'); frame.innerHTML = ''; }" } %>
      </div>
    <% end %>

    <%= turbo_frame_tag "bug_assignees_frame_#{bug.id || 'new'}" do %>
      <% current_project_id = bug.project_id || @selected_project&.id || params[:project_id] %>
      <% if current_project_id.present? %>
        <% project_devs = User.developer.joins(:projects).where(projects: { id: current_project_id }).distinct.order(:name) %>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label mb-1 fw-bold">Assign Dev</label>
            <div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
              <%= f.collection_radio_buttons :assignee_dev_id, project_devs, :id, :name, {}, { required: true } do |b| %>
                <% user = b.object %>
                <label class="assign-list__item border-bottom mb-0">
                  <div class="assign-list__avatar">
                    <% if user.profile_picture.attached? %>
                      <%= image_tag user.profile_picture, alt: user.name %>
                    <% else %>
                      <span><%= user.name.to_s.first&.upcase || "U" %></span>
                    <% end %>
                  </div>
                  <span class="assign-list__name"><%= user.name %></span>
                  <%= b.radio_button class: 'form-check-input ms-auto' %>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>

    <div class="mb-3">
      <%= f.label :deadline, "Due date", class: "form-label" %>
      <%= f.date_field :deadline, class: "form-control app-input" %>
    </div>

    <div class="mb-3">
      <%= f.label :title, "Bug title", class: "form-label" %>
      <%= f.text_field :title, class: "form-control app-input" %>
    </div>

    <div class="mb-3">
      <%= f.label :description, "Bug details", class: "form-label" %>
      <%= f.text_area :description, rows: 3, class: "form-control app-input" , required: true%>
    </div>

    <div class="mb-3">
      <%= f.label :bug_type, "Bug type", class: "form-label" %>
      <%= f.select :bug_type, options_for_select([ [ "Feature", "feature" ], [ "Bug", "bug" ] ], bug.bug_type), {}, { class: "form-select app-input", onchange: "this.form.requestSubmit()" } %>
    </div>

    <div class="mb-3">
      <%= f.label :screenshot, "Screenshot", class: "form-label" %>
      <%= f.file_field :screenshot, class: "form-control app-input" %>
    </div>
  <% end %>

  <div class="modal-footer border-0 pt-2 px-0">
    <%= f.submit class: "btn btn-primary app-btn px-4" %>
  </div>
<% end %>
