<%= render 'shared/dashboard_nav' %>

<div class="container app-shell py-4">
	<div class="d-flex align-items-center mb-3 flex-wrap gap-2">
		<h1 class="page-heading m-0 me-2"><%= @bug.title %></h1>
		</div>
		
		<div class="mb-4 text-muted" style="font-size: 1.05rem; line-height: 1.6; background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
			<p>Project Name:</p>
			<span class="badge bg-secondary align-middle"><%= @bug.project&.name %></span>
		
		</div>

		<div class="mb-4 text-muted" style="font-size: 1.05rem; line-height: 1.6; background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
			<p>Bug Type:</p>
			<span class="badge bg-secondary align-middle"><%= @bug.bug_type %></span>
		
		</div>
		
		<div class="mb-4 text-muted" style="font-size: 1.05rem; line-height: 1.6; background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
			<p>Bug Status:</p>
			<% status_class = @bug.status == 'open' ? 'pending' : (@bug.status == 'in_progress' ? 'progress' : 'closed') %>
			<span class="status-badge status-badge--<%= status_class %> align-middle"><%= @bug.status.titleize %></span>
		
		</div>


	<div class="mb-4 text-muted" style="font-size: 1.05rem; line-height: 1.6; background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
		<p>Description:</p>
		<%= simple_format(@bug.description) %>
	</div>

	<% if @bug.screenshot.attached? %>
		<div class="mb-5">
			<h5 class="text-uppercase text-muted" style="font-size: 0.8rem; letter-spacing: 0.05em; font-weight: 700; margin-bottom: 0.8rem;">Screenshot</h5>
			<%= image_tag @bug.screenshot, class: 'img-fluid rounded shadow-sm border', style: 'max-height:320px;object-fit:contain;' %>
		</div>
	<% end %>
	

	
	<div class="mb-4" style="background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
		<div class="col-auto me-4">
			<h5 class="text-uppercase text-muted" style="font-size: 0.8rem; letter-spacing: 0.05em; font-weight: 700; margin-bottom: 0.8rem;">Assigned QA</h5>
			<%=@bug.assignee_qa.name %>
			<% if @bug.assignee_qa&.profile_picture&.attached? %>
				<%= image_tag @bug.assignee_qa.profile_picture, class: 'rounded-circle shadow-sm', style: 'width:48px;height:48px;object-fit:cover;', title: @bug.assignee_qa.name, data: { bs_toggle: "tooltip" } %>
			<% else %>
				<div class="rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width:48px;height:48px; background-color: #d9e3f5; color: #28436f; font-weight: 700;" title="<%= @bug.assignee_qa.name %>" data-bs-toggle="tooltip">
					<%= @bug.assignee_qa&.name.to_s.first&.upcase || "U" %>
				</div>
			<% end %>
		</div>
	</div>

	<div class="mb-4" style="background-color: #f8f9fa; padding: 1.5rem; border-radius: 0.5rem;">
		<div class="col-auto me-4">
			<h5 class="text-uppercase text-muted" style="font-size: 0.8rem; letter-spacing: 0.05em; font-weight: 700; margin-bottom: 0.8rem;">Assigned DEV</h5>
			<%=@bug.assignee_dev.name %>
			<% if @bug.assignee_dev&.profile_picture&.attached? %>
				<%= image_tag @bug.assignee_qa.profile_picture, class: 'rounded-circle shadow-sm', style: 'width:48px;height:48px;object-fit:cover;', title: @bug.assignee_dev.name, data: { bs_toggle: "tooltip" } %>
			<% else %>
				<div class="rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width:48px;height:48px; background-color: #d9e3f5; color: #28436f; font-weight: 700;" title="<%= @bug.assignee_dev.name %>" data-bs-toggle="tooltip">
					<%= @bug.assignee_dev&.name.to_s.first&.upcase || "U" %>
				</div>
			<% end %>
		</div>
	</div>

	
	<div class="mb-3 pt-4 border-top">
		<% if can? :change_status, @bug %>
			<%= form_with url: change_status_bug_path(@bug), method: :patch, data: { turbo: true }, local: false do |f| %>
				<div class="d-flex align-items-center gap-3">
					<label class="form-check-label">
						<%= f.radio_button :status, 'open', checked: (@bug.status == 'open' || @bug.status.blank?), class: 'form-check-input me-2' %>
						Pending
					</label>
					<label class="form-check-label">
						<%= f.radio_button :status, 'in_progress', checked: (@bug.status == 'in_progress'), class: 'form-check-input me-2' %>
						In progress
					</label>
					<label class="form-check-label">
						<%= f.radio_button :status, 'resolved', checked: (@bug.status == 'resolved'), class: 'form-check-input me-2' %>
						Closed
					</label>
					<%= f.submit 'Change status', class: 'btn btn-primary app-btn ms-3' %>
				</div>
			<% end %>
		<% end %>
		<% if can? :update, @bug %>
			<button type="button" class="btn btn-outline-secondary app-btn me-2" data-bs-toggle="modal" data-bs-target="#editBugModal_<%= @bug.id %>">Edit</button>
		<% end %>
		<% if can? :destroy, @bug %>
			<%= link_to 'Delete', bug_path(@bug), data: { turbo_method: :delete, turbo_confirm: 'Delete bug?' }, class: 'btn btn-outline-danger app-btn' %>
		<% end %>
	</div>
</div>

<% if can? :update, @bug %>
	<div class="modal fade" id="editBugModal_<%= @bug.id %>" tabindex="-1" aria-labelledby="editBugModalLabel_<%= @bug.id %>" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered app-modal app-modal--bug">
			<div class="modal-content">
				<div class="modal-header border-0">
					<h2 class="modal-title app-modal__title" id="editBugModalLabel_<%= @bug.id %>">Edit bug</h2>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>

				<div class="modal-body pt-0">
					<%= form_with(model: @bug, url: bug_path(@bug), local: true, multipart: true) do |f| %>
						<% 
							project_qas = User.joins(:projects).where(role: 'qa', projects: { id: @bug.project_id }).distinct 
							project_devs = User.joins(:projects).where(role: 'developer', projects: { id: @bug.project_id }).distinct
						%>
						<div class="row">
							<div class="col-md-6 mb-3">
								<label class="form-label mb-1 fw-bold">Assign Dev</label>
								<div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
									<%= f.collection_radio_buttons :assignee_dev_id, project_devs, :id, :name do |b| %>
										<% user = b.object %>
										<label class="assign-list__item border-bottom mb-0" for="show_edit_bug_<%= @bug.id %>_assignee_dev_id_<%= user.id %>">
											<div class="assign-list__avatar">
												<% if user.profile_picture.attached? %>
													<%= image_tag user.profile_picture, alt: user.name %>
												<% else %>
													<span><%= user.name.to_s.first&.upcase || "U" %></span>
												<% end %>
											</div>
											<span class="assign-list__name"><%= user.name %></span>
											<%= b.radio_button class: 'form-check-input ms-auto', id: "show_edit_bug_#{@bug.id}_assignee_dev_id_#{user.id}" %>
										</label>
									<% end %>
								</div>
							</div>
							
							<div>
								<%= f.label :deadline, "Due date", class: "form-label mb-1" %>
								<%= f.date_field :deadline, class: "form-control app-input" %>
							</div>

						<div class="mb-3 mt-2">
							<%= f.text_field :title, class: "form-control app-input app-input--title", placeholder: "Add title here" %>
						</div>

						<div class="mb-3">
							<%= f.label :description, "Bug details", class: "form-label" %>
							<%= f.text_area :description, rows: 2, class: "form-control app-input", placeholder: "Add here" %>
						</div>

						

						<div class="upload-dropzone mb-3">
							<%= f.label :screenshot, class: "upload-dropzone__label" do %>
								<i class="bi bi-cloud-arrow-up"></i>
								Drop new file here to replace screenshot or <span>browse</span>
							<% end %>
							<%= f.file_field :screenshot, class: "d-none" %>
						</div>

						<div class="modal-footer border-0 pt-2 px-0">
							<%= f.submit "Update", class: "btn btn-primary app-btn px-4" %>
						</div>
					<% end %>
				</div>
			</div>
		</div>
	</div>
<% end %>
