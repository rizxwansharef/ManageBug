<%= render 'shared/dashboard_nav' %>

<div class="container app-shell py-4">
	<div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-3">
		<div>
			<p class="app-breadcrumb mb-2">
				<%= link_to "Projects", projects_path, class: "app-breadcrumb__link" %>
				<span class="mx-2">&gt;</span>
				<span><%= @selected_project&.name || "All Projects" %></span>
			</p>
			<div class="d-flex align-items-center gap-2">
				<h1 class="page-heading mb-0">All bugs <% if @selected_project %>"<%= @selected_project.name %>"<% end %></h1>
			</div>
		</div>

		<% if can?(:create, Bug) && (@selected_project.present? || current_user.projects.any?) %>
			<button class="btn btn-primary app-btn" data-bs-toggle="modal" data-bs-target="#newBugModal" type="button">+ New Task bug</button>
		<% end %>
	</div>

	<div class="bugs-toolbar">
		<div class="bugs-search">
			<i class="bi bi-search"></i>
			<input type="text" placeholder="Search" id="bugSearchInput" />
		</div>
		<div class="d-flex align-items-center gap-2">
			<button class="btn btn-light btn-sm" id="gridViewBtn" onclick="switchView('grid')"><i class="bi bi-grid"></i></button>
			<button class="btn btn-light btn-sm" id="listViewBtn" onclick="switchView('list')"><i class="bi bi-list"></i></button>
		</div>
	</div>

	<div class="bugs-table-wrap">
		<table class="table bugs-table mb-0" id="bugsTable">
			<thead>
				<tr>
					<th>Bug details</th>
					<th>Status</th>
					<th>Due Date</th>
					<th>Assigned To</th>
					<th class="text-center">Action</th>
				</tr>
			</thead>
			<tbody>
				<% @bugs.each do |bug| %>
					
					<tr>
						<td>
							<div class="bug-title-cell">
								<span class="bug-dot <%= %w[resolved completed].include?(bug.status) ? "bug-dot--green" : bug.status == "started" ? "bug-dot--blue" : "bug-dot--red" %>"></span>
								<%= link_to bug.title, bug_path(bug), class: "bug-link" %>
							</div>
						</td>
						<td><span class="badge bg-secondary"><%= bug.status.titleize %></span></td>
						<td><span class="text-muted"><i class="bi bi-calendar3"></i> <%= bug.deadline&.strftime("%d %b") || "-" %></span></td>
						<td>
							<div class="avatar-stack">
								<% [bug.assignee_dev, bug.assignee_qa].compact.each do |assignee| %>
									<span class="avatar-stack__item" title="<%= assignee.name %>">
										<% if assignee.profile_picture.attached? %>
											<%= image_tag assignee.profile_picture, alt: assignee.name %>
										<% else %>
											<span><%= assignee.name.to_s.first&.upcase || "U" %></span>
										<% end %>
									</span>
								<% end %>
							</div>
						</td>
						<td class="text-center">
							<div class="dropdown">
								<button class="btn btn-sm btn-light" id="bugDropdown<%= bug.id %>" data-bs-toggle="dropdown" type="button" aria-expanded="false"><i class="bi bi-three-dots-vertical"></i></button>
								<div class="dropdown-menu dropdown-menu-end p-3" aria-labelledby="bugDropdown<%= bug.id %>" style="min-width:220px;">

									<% if can? :destroy, bug %>
										<% if can? :change_status, bug %><hr class="dropdown-divider my-2"><% end %>
										<%= link_to "Delete", bug_path(bug), data: { turbo_method: :delete, turbo_confirm: "Delete bug?" }, class: "dropdown-item text-danger" %>
									<% end %>
									<% if can? :update, bug %>
										<% if (can? :change_status, bug) || (can? :edit, bug) %><hr class="dropdown-divider my-2"><% end %>
										<a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#editBugModal_<%= bug.id %>"onclick="document.querySelectorAll('.modal-backdrop').forEach(el => el.remove()); document.body.style.overflow = 'auto';">Edit</a>
										<% end %>
									<% unless (can? :change_status, bug) || (can? :destroy, bug) || (can? :update, bug) %>
										<p class="text-muted small mb-0">No actions available</p>
									<% end %>
								</div>
							</div>
						</td>
					</tr>
				<% end %>
			</tbody>
		</table>

		<% if @bugs.empty? %>
			<div class="empty-state p-4">No bugs found for this view.</div>
		<% end %>
	</div>
</div>



<% @bugs.each do |bug| %>
		<div class="modal fade" id="editBugModal_<%= bug.id %>" tabindex="-1" aria-labelledby="editBugModalLabel_<%= bug.id %>" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered app-modal app-modal--bug">
				<div class="modal-content">
					<div class="modal-header border-0">
						<h2 class="modal-title app-modal__title" id="editBugModal_<%= bug.id %>">Edit bug</h2>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
						
					</div>
					<div class="modal-body pt-0">
						<%= render "edit_form", bug: bug %>
					</div>
				</div>
			</div>
		</div>
<% end %>

<%= render "new" %>

	<script>
		// Make switchView globally accessible
		window.switchView = function(view) {
			const gridBtn = document.getElementById('gridViewBtn');
			const listBtn = document.getElementById('listViewBtn');
			
			if (!gridBtn || !listBtn) return;
			
			// Remove active state from both
			gridBtn.classList.remove('btn-primary');
			gridBtn.classList.add('btn-light');
			listBtn.classList.remove('btn-primary');
			listBtn.classList.add('btn-light');
			
			const tableWrap = document.querySelector('.bugs-table-wrap');

			// Add active state to selected
			if (view === 'grid') {
				gridBtn.classList.add('btn-primary');
				gridBtn.classList.remove('btn-light');
				localStorage.setItem('bugViewMode', 'grid');
				if(tableWrap) tableWrap.classList.add('bugs-grid-view');
			} else if (view === 'list') {
				listBtn.classList.add('btn-primary');
				listBtn.classList.remove('btn-light');
				localStorage.setItem('bugViewMode', 'list');
				if(tableWrap) tableWrap.classList.remove('bugs-grid-view');
			}
		};

		function initBugSearch() {
			var input = document.getElementById("bugSearchInput");
			var table = document.getElementById("bugsTable");
			if (!input || !table) return;

			input.addEventListener("input", function () {
				var q = input.value.toLowerCase();
				table.querySelectorAll("tbody tr").forEach(function (row) {
					row.style.display = row.innerText.toLowerCase().includes(q) ? "" : "none";
				});
			}, { once: false });
		}

		function initViewButtons() {
			const savedView = localStorage.getItem('bugViewMode') || 'grid';
			window.switchView(savedView);
		}

		// Initialize on DOM ready
		if (document.readyState === 'loading') {
			document.addEventListener("DOMContentLoaded", function() {
				initBugSearch();
				initViewButtons();
			});
		} else {
			initBugSearch();
			initViewButtons();
		}
		
		// Also reinitialize on turbo:load
		document.addEventListener("turbo:load", function() {
			initBugSearch();
			initViewButtons();
		});
	</script>
</div>
