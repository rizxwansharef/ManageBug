<%= render 'shared/dashboard_nav' %>

<div class="container">
	<h1>Bugs</h1>
	<div class="mb-3">
        <% if can? :create, Bug %>  
			<%= link_to 'New Bug', new_bug_path, class: 'btn btn-primary' %>
		<% end %>
	</div>

	<% if params[:project_id].present? %>
		<% project = Project.find_by(id: params[:project_id]) %>
		<h5>Project: <%= project&.name || 'Unknown' %></h5>
	<% end %>

	<% if @bugs.any? %>
		<div class="list-group">
			<% @bugs.each do |bug| %>
				<div class="list-group-item d-flex justify-content-between align-items-center">
					<div>
						<h5 class="mb-1"><%= link_to bug.title, bug_path(bug) %></h5>
						<p class="mb-0 text-muted">Status: <%= bug.status %> • Project: <%= bug.project&.name %></p>
					</div>
					<div>
						<% if can? :update, bug %>
							<%= link_to 'Edit', edit_bug_path(bug), class: 'btn btn-sm btn-outline-secondary me-2' %>
						<% end %>
						<% if can? :destroy, bug %>
							<%= link_to 'Delete', bug_path(bug), data: { turbo_method: :delete, turbo_confirm: 'Delete bug?' }, class: 'btn btn-sm btn-danger' %>
						<% end %>
					</div>
				</div>
			<% end %>
		</div>
	<% else %>
		<p>No bugs found.</p>
	<% end %>
</div>
