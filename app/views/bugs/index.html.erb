<%= render 'shared/dashboard_nav' %>

<div class="container app-shell py-4">
	<div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-3">
		<div>
			<p class="app-breadcrumb mb-2">
				<%= link_to "Projects", projects_path, class: "app-breadcrumb__link" %>
				<span class="mx-2">&gt;</span>
				<span><%= @selected_project&.name || "All Projects" %></span>
			</p>
			<div class="d-flex align-items-center gap-2">
				<h1 class="page-heading mb-0">All bugs <% if @selected_project %>"<%= @selected_project.name %>"<% end %></h1>
			</div>
		</div>

		<% if can?(:create, Bug) && (@selected_project.present? || current_user.projects.any?) %>
			<button class="btn btn-primary app-btn" data-bs-toggle="modal" data-bs-target="#newBugModal" type="button">+ New Task bug</button>
		<% end %>
	</div>

	<div class="bugs-toolbar">
		<div class="bugs-search">
			<i class="bi bi-search"></i>
			<input type="text" placeholder="Search" id="bugSearchInput" />
		</div>
		<div class="d-flex align-items-center gap-2">
			<button class="btn btn-light btn-sm" id="gridViewBtn" onclick="switchView('grid')"><i class="bi bi-grid"></i></button>
			<button class="btn btn-light btn-sm" id="listViewBtn" onclick="switchView('list')"><i class="bi bi-list"></i></button>
		</div>
	</div>

	<div class="bugs-table-wrap">
		<table class="table bugs-table mb-0" id="bugsTable">
			<thead>
				<tr>
					<th>Bug details</th>
					<th>Status</th>
					<th>Due Date</th>
					<th>Assigned To</th>
					<th class="text-center">Action</th>
				</tr>
			</thead>
			<tbody>
				<% @bugs.each do |bug| %>
					<% display_status = case bug.status
						 when "resolved" then "Closed"
						 when "in_progress" then "In progress"
						 else "Pending"
						 end %>
					<% status_class = case bug.status
						 when "resolved" then "status-badge status-badge--closed"
						 when "in_progress" then "status-badge status-badge--progress"
						 else "status-badge status-badge--pending"
						 end %>
					<tr>
						<td>
							<div class="bug-title-cell">
								<span class="bug-dot <%= bug.status == "resolved" ? "bug-dot--green" : bug.status == "in_progress" ? "bug-dot--blue" : "bug-dot--red" %>"></span>
								<%= link_to bug.title, bug_path(bug), class: "bug-link" %>
							</div>
						</td>
						<td><span class="<%= status_class %>"><%= display_status %></span></td>
						<td><span class="text-muted"><i class="bi bi-calendar3"></i> <%= bug.deadline&.strftime("%d %b") || "-" %></span></td>
						<td>
							<div class="avatar-stack">
								<% [bug.assignee_dev, bug.assignee_qa].compact.each do |assignee| %>
									<span class="avatar-stack__item" title="<%= assignee.name %>">
										<% if assignee.profile_picture.attached? %>
											<%= image_tag assignee.profile_picture, alt: assignee.name %>
										<% else %>
											<span><%= assignee.name.to_s.first&.upcase || "U" %></span>
										<% end %>
									</span>
								<% end %>
							</div>
						</td>
						<td class="text-center">
							<div class="dropdown">
								<button class="btn btn-sm btn-light" id="bugDropdown<%= bug.id %>" data-bs-toggle="dropdown" type="button" aria-expanded="false"><i class="bi bi-three-dots-vertical"></i></button>
								<div class="dropdown-menu dropdown-menu-end p-3" aria-labelledby="bugDropdown<%= bug.id %>" style="min-width:220px;">
									<% if can? :change_status, bug %>
										<%= form_with url: change_status_bug_path(bug), method: :patch, data: { turbo: true }, local: false do |f| %>
											<div class="form-check">
												<label class="form-check-label d-flex align-items-center gap-2">
													<%= f.radio_button :status, 'open', checked: (bug.status == 'open' || bug.status.blank?), class: 'form-check-input me-2', id: "status_open_#{bug.id}" %>
													Pending
												</label>
											</div>
											<div class="form-check mt-2">
												<label class="form-check-label d-flex align-items-center gap-2">
													<%= f.radio_button :status, 'in_progress', checked: (bug.status == 'in_progress'), class: 'form-check-input me-2', id: "status_in_progress_#{bug.id}" %>
													In progress
												</label>
											</div>
											<div class="form-check mt-2">
												<label class="form-check-label d-flex align-items-center gap-2">
													<%= f.radio_button :status, 'resolved', checked: (bug.status == 'resolved'), class: 'form-check-input me-2', id: "status_resolved_#{bug.id}" %>
													Closed
												</label>
											</div>
											<div class="mt-3 text-end">
												<%= f.submit 'Change status', class: 'btn btn-primary btn-sm' %>
											</div>
										<% end %>
									<% end %>
									<% if can? :destroy, bug %>
										<% if can? :change_status, bug %><hr class="dropdown-divider my-2"><% end %>
										<%= link_to "Delete", bug_path(bug), data: { turbo_method: :delete, turbo_confirm: "Delete bug?" }, class: "dropdown-item text-danger" %>
									<% end %>
									<% if can? :update, bug %>
										<% if (can? :change_status, bug) || (can? :destroy, bug) %><hr class="dropdown-divider my-2"><% end %>
										<a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#editBugModal_<%= bug.id %>"onclick="document.querySelectorAll('.modal-backdrop').forEach(el => el.remove()); document.body.style.overflow = 'auto';">Edit</a>
										<% end %>
									<% unless (can? :change_status, bug) || (can? :destroy, bug) || (can? :update, bug) %>
										<p class="text-muted small mb-0">No actions available</p>
									<% end %>
								</div>
							</div>
						</td>
					</tr>
				<% end %>
			</tbody>
		</table>

		<% if @bugs.empty? %>
			<div class="empty-state p-4">No bugs found for this view.</div>
		<% end %>
	</div>
</div>

<% if can?(:create, Bug) && (@selected_project.present? || current_user.projects.any?) %>
	<div class="modal fade" id="newBugModal" tabindex="-1" aria-labelledby="newBugModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered app-modal app-modal--bug">
			<div class="modal-content">
				<div class="modal-header border-0">
					<h2 class="modal-title app-modal__title" id="newBugModalLabel">Add new bug</h2>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>

				<div class="modal-body pt-0">
					<%= form_with(model: @new_bug, url: bugs_path, local: true, multipart: true) do |f| %>
						<% if @selected_project.present? %>
							<%= f.hidden_field :project_id, value: @selected_project.id %>
						<% else %>
							<div class="mb-3">
							<%= f.label :project_id, "Select Project", class: "form-label mb-1 fw-bold" %>
  							<%= f.collection_select :project_id, current_user.projects, :id, :name, { prompt: "Choose a project" }, { class: "form-select app-input", required: true, onchange: "let frame = document.getElementById('available_users_frame'); if(this.value) { frame.src = '/projects/' + this.value + '/available_users'; } else { frame.innerHTML = '<div class=\"row\"><div class=\"col-md-6 mb-3\"><label class=\"form-label mb-1 fw-bold\">Assign Dev</label><div class=\"assign-list shadow-sm p-3 text-muted small\">Please select a project first.</div></div><div class=\"col-md-6 mb-3\"><label class=\"form-label mb-1 fw-bold\">Assign QA</label><div class=\"assign-list shadow-sm p-3 text-muted small\">Please select a project first.</div></div></div>'; }" } %>
				</div>

						<% end %>

							<div class="row">
								<div class="col-md-6 mb-3">
									<label class="form-label mb-1 fw-bold">Assign Dev</label>
									<div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
										<%= f.collection_radio_buttons :assignee_dev_id, @available_devs, :id, :name, {}, { required: true } do |b| %>
											<% user = b.object %>
											<label class="assign-list__item border-bottom mb-0">
												<div class="assign-list__avatar">
													<% if user.profile_picture.attached? %>
														<%= image_tag user.profile_picture, alt: user.name %>
													<% else %>
														<span><%= user.name.to_s.first&.upcase || "U" %></span>
													<% end %>
												</div>
												<span class="assign-list__name"><%= user.name %></span>
												<%= b.radio_button class: 'form-check-input ms-auto' %>
											</label>
										<% end %>
									</div>
								</div>
								<div class="col-md-6 mb-3">
									<label class="form-label mb-1 fw-bold">Assign QA</label>
									<div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
										<%= f.collection_radio_buttons :assignee_qa_id, @available_qas, :id, :name, {}, { required: true } do |b| %>
											<% user = b.object%>
											<label class="assign-list__item border-bottom mb-0">
												<div class="assign-list__avatar">
													<% if user.profile_picture.attached? %>
														<%= image_tag user.profile_picture, alt: user.name %>
													<% else %>
														<span><%= user.name.to_s.first&.upcase || "U" %></span>
													<% end %>
												</div>
												<span class="assign-list__name"><%= user.name %></span>
												<%= b.radio_button class: 'form-check-input ms-auto' %>
											</label>
										<% end %>
									</div>
								</div>
							</div>
							<div>
								<%= f.label :deadline, "Add due date", class: "form-label mb-1" %>
								<%= f.date_field :deadline, class: "form-control app-input" %>
							</div>
						

						<div class="mb-3 mt-2">
							<%= f.label :title, "Bug title", class: "form-label" %>
							<%= f.text_field :title, class: "form-control app-input app-input--title", placeholder: "Add title here", required: true %>
						</div>

						<div class="mb-3">
							<%= f.label :description, "Bug details", class: "form-label" %>
							<%= f.text_area :description, rows: 2, class: "form-control app-input", placeholder: "Add here", required: true %>
						</div>

						<div class="upload-dropzone mb-3">
							<%= f.label :screenshot, class: "upload-dropzone__label" do %>
								<i class="bi bi-cloud-arrow-up"></i>
								Select Image <span>browse</span>
							<% end %>
							<%= f.file_field :screenshot, class: "d-none" %>
						</div>

						<div class="modal-footer border-0 pt-2 px-0">
						
							<%= f.submit "Add", class: "btn btn-primary app-btn px-4" %>
						</div>
					<% end %>
				</div>
			</div>
		</div>
	</div>
<% end %>

<% @bugs.each do |bug| %>
	<% if can? :update, bug %>
		<div class="modal fade" id="editBugModal_<%= bug.id %>" tabindex="-1" aria-labelledby="editBugModalLabel_<%= bug.id %>" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered app-modal app-modal--bug">
				<div class="modal-content">
					<div class="modal-header border-0">
						<h2 class="modal-title app-modal__title" id="editBugModalLabel_<%= bug.id %>">Edit bug</h2>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>

					<div class="modal-body pt-0">
						<%= form_with(model: bug, url: bug_path(bug), local: true, multipart: true) do |f| %>
							<% 
								project_qas = User.joins(:projects).where(role: 'qa', projects: { id: bug.project_id }).distinct 
								project_devs = User.joins(:projects).where(role: 'developer', projects: { id: bug.project_id }).distinct
							%>
							<div class="row">
								<div class="col-md-6 mb-3">
									<label class="form-label mb-1 fw-bold">Assign Dev</label>
									<div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
										<%= f.collection_radio_buttons :assignee_dev_id, project_devs, :id, :name do |b| %>
											<% user = b.object %>
											<label class="assign-list__item border-bottom mb-0">
												<div class="assign-list__avatar">
													<% if user.profile_picture.attached? %>
														<%= image_tag user.profile_picture, alt: user.name %>
													<% else %>
														<span><%= user.name.to_s.first&.upcase || "U" %></span>
													<% end %>
												</div>
												<span class="assign-list__name"><%= user.name %></span>
												<%= b.radio_button class: 'form-check-input ms-auto' %>
											</label>
										<% end %>
									</div>
								</div>
								<div class="col-md-6 mb-3">
									<label class="form-label mb-1 fw-bold">Assign QA</label>
									<div class="assign-list shadow-sm" style="max-height: 160px; overflow-y: auto;">
										<%= f.collection_radio_buttons :assignee_qa_id, project_qas, :id, :name do |b| %>
											<% user = b.object %>
											<label class="assign-list__item border-bottom mb-0">
												<div class="assign-list__avatar">
													<% if user.profile_picture.attached? %>
														<%= image_tag user.profile_picture, alt: user.name %>
													<% else %>
														<span><%= user.name.to_s.first&.upcase || "U" %></span>
													<% end %>
												</div>
												<span class="assign-list__name"><%= user.name %></span>
												<%= b.radio_button class: 'form-check-input ms-auto' %>
											</label>
										<% end %>
									</div>
								</div>
							</div>
								<div>
									<%= f.label :deadline, "Due date", class: "form-label mb-1" %>
									<%= f.date_field :deadline, class: "form-control app-input" %>
								</div>
						
								<div class="mb-3 mt-2">
									<%= f.label :title, "Bug title", class: "form-label" %>
									<%= f.text_field :title, class: "form-control app-input app-input--title", placeholder: "Add title here" %>
								</div>

								<div class="mb-3 ">
									<%= f.label :description, "Bug details", class: "form-label" %>
									<%= f.text_area :description, rows: 2, class: "form-control app-input", placeholder: "Add here" %>
								</div>
							</div>
							<div class="upload-dropzone mb-3">
								<%= f.label :screenshot, class: "upload-dropzone__label" do %>
									<i class="bi bi-cloud-arrow-up"></i>
									Drop new file here to replace screenshot or <span>browse</span>
								<% end %>
								<%= f.file_field :screenshot, class: "d-none" %>
							</div>
						
							<div class="modal-footer border-0 pt-2 px-0">
								<%= f.submit "Update", class: "btn btn-primary app-btn px-4" %>
							</div>
						<% end %>
					</div>
				</div>
			</div>
		</div>
	<% end %>
<% end %>

<script>
	// Make switchView globally accessible
	window.switchView = function(view) {
		const gridBtn = document.getElementById('gridViewBtn');
		const listBtn = document.getElementById('listViewBtn');
		
		if (!gridBtn || !listBtn) return;
		
		// Remove active state from both
		gridBtn.classList.remove('btn-primary');
		gridBtn.classList.add('btn-light');
		listBtn.classList.remove('btn-primary');
		listBtn.classList.add('btn-light');
		
		const tableWrap = document.querySelector('.bugs-table-wrap');

		// Add active state to selected
		if (view === 'grid') {
			gridBtn.classList.add('btn-primary');
			gridBtn.classList.remove('btn-light');
			localStorage.setItem('bugViewMode', 'grid');
			if(tableWrap) tableWrap.classList.add('bugs-grid-view');
		} else if (view === 'list') {
			listBtn.classList.add('btn-primary');
			listBtn.classList.remove('btn-light');
			localStorage.setItem('bugViewMode', 'list');
			if(tableWrap) tableWrap.classList.remove('bugs-grid-view');
		}
	};

	function initBugSearch() {
		var input = document.getElementById("bugSearchInput");
		var table = document.getElementById("bugsTable");
		if (!input || !table) return;

		input.addEventListener("input", function () {
			var q = input.value.toLowerCase();
			table.querySelectorAll("tbody tr").forEach(function (row) {
				row.style.display = row.innerText.toLowerCase().includes(q) ? "" : "none";
			});
		}, { once: false });
	}

	function initViewButtons() {
		const savedView = localStorage.getItem('bugViewMode') || 'grid';
		window.switchView(savedView);
	}

	// Initialize on DOM ready
	if (document.readyState === 'loading') {
		document.addEventListener("DOMContentLoaded", function() {
			initBugSearch();
			initViewButtons();
		});
	} else {
		initBugSearch();
		initViewButtons();
	}
	
	// Also reinitialize on turbo:load
	document.addEventListener("turbo:load", function() {
		initBugSearch();
		initViewButtons();
	});
</script>
</div>
